{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Task 2: EDA & Data Pipeline — Wikipedia Next-Click Prediction\n",
    "\n",
    "Given `current_article_id` and `target_article_id`, predict `next_article_id`.\n",
    "\n",
    "**Metric**: Accuracy (exact match)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "import pickle\n",
    "from tqdm import tqdm\n",
    "\n",
    "import torch\n",
    "from sentence_transformers import SentenceTransformer\n",
    "\n",
     "def _load_adjacency(arts, cache_dir):\n",
     "    import pickle, tarfile, io, urllib.request, urllib.parse\n",
     "    for p in [cache_dir / 'wikispeedia_adj.pkl', Path('dataset-task2') / 'wikispeedia_adj.pkl']:\n",
     "        if p.exists():\n",
     "            with open(p, 'rb') as f:\n",
     "                return pickle.load(f)\n",
     "    title_to_id = dict(zip(arts['title'].str.strip(), arts['article_id']))\n",
     "    url = 'https://snap.stanford.edu/data/wikispeedia/wikispeedia_paths-and-graph.tar.gz'\n",
     "    print(f'Downloading Wikispeedia from {url} ...')\n",
     "    with urllib.request.urlopen(url) as resp:\n",
     "        with tarfile.open(fileobj=io.BytesIO(resp.read()), mode='r:gz') as tar:\n",
     "            f = tar.extractfile('wikispeedia_paths-and-graph/links.tsv')\n",
     "            content = f.read()\n",
     "    links = pd.read_csv(io.BytesIO(content), sep='\\t', skiprows=14,\n",
     "                        header=None, names=['source', 'target'])\n",
     "    links['sid'] = links['source'].apply(\n",
     "        lambda x: urllib.parse.unquote(x).replace('_', ' ').strip()).map(title_to_id)\n",
     "    links['tid'] = links['target'].apply(\n",
     "        lambda x: urllib.parse.unquote(x).replace('_', ' ').strip()).map(title_to_id)\n",
     "    links = links.dropna(subset=['sid', 'tid'])\n",
     "    adj = {i: [] for i in range(len(arts))}\n",
     "    for _, r in links.iterrows():\n",
     "        adj[int(r['sid'])].append(int(r['tid']))\n",
     "    adj = {k: list(set(v)) for k, v in adj.items()}\n",
     "    with open(cache_dir / 'wikispeedia_adj.pkl', 'wb') as f:\n",
     "        pickle.dump(adj, f)\n",
     "    return adj\n",
     "\n",
     "def _make_sub(state_ids, preds, path):\n",
     "    pd.DataFrame({'state_id': state_ids, 'predicted_next_article_id': preds}).to_csv(path, index=False)\n"
    "\n",
"ROOT = Path.cwd()\n",
"while not (ROOT / 'dataset-task2').exists() and ROOT != ROOT.parent:\n",
"    ROOT = ROOT.parent\n",
"DATA = ROOT / 'dataset-task2'\n",
"CACHE = ROOT / '.cache'\n",
"CACHE.mkdir(exist_ok=True)\n",
    "\n",
    "%matplotlib inline\n",
    "sns.set_style('whitegrid')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Basic Data Loading"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
     "articles = pd.read_csv(DATA / 'articles.csv')\n",
     "categories = pd.read_csv(DATA / 'categories.csv')\n",
     "train = pd.read_csv(DATA / 'states_train.csv')\n",
     "test = pd.read_csv(DATA / 'states_test.csv')\n",
     "sample_sub = pd.read_csv(DATA / 'sample_submission.csv')\n",
    "\n",
    "print(f'Articles: {articles.shape}')\n",
    "print(f'Categories: {categories.shape}')\n",
    "print(f'Train states: {train.shape}')\n",
    "print(f'Test states: {test.shape}')\n",
    "print(f'Sample submission: {sample_sub.shape}')\n",
    "\n",
    "train.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Validate training data: every next_article_id should exist in articles"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "all_ids = set(articles['article_id'])\n",
    "print(f'Article IDs range: {articles.article_id.min()} to {articles.article_id.max()}')\n",
    "print(f'Unique articles in train current: {train.current_article_id.nunique()}')\n",
    "print(f'Unique articles in train target: {train.target_article_id.nunique()}')\n",
    "print(f'Unique articles in train next: {train.next_article_id.nunique()}')\n",
    "print(f'All next_article_ids valid: {train.next_article_id.isin(all_ids).all()}')\n",
    "print(f'All current_article_ids valid: {train.current_article_id.isin(all_ids).all()}')\n",
    "print(f'All target_article_ids valid: {train.target_article_id.isin(all_ids).all()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Categories per article\n",
    "cat_counts = categories.groupby('article_id').size()\n",
    "print(f'Articles with at least 1 category: {len(cat_counts)}')\n",
    "print(f'Categories per article - mean: {cat_counts.mean():.1f}, max: {cat_counts.max()}')\n",
    "\n",
    "cat_counts.hist(bins=20, figsize=(8, 4))\n",
    "plt.title('Distribution of categories per article')\n",
    "plt.xlabel('Number of categories')\n",
    "plt.ylabel('Count')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Link Graph from Wikispeedia\n",
    "\n",
    "The article set matches the Wikispeedia dataset (4604 articles, 119,880 edges). Using the SNAP graph directly."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
     "adj = _load_adjacency(articles, CACHE)\n",
    "n_nodes = len(adj)\n",
    "degrees = [len(adj[i]) for i in range(n_nodes)]\n",
    "\n",
    "print(f'Link graph: {n_nodes} nodes, {sum(degrees)} edges')\n",
    "print(f'Avg out-degree: {np.mean(degrees):.1f}')\n",
    "print(f'Min out-degree: {min(degrees)}, Max out-degree: {max(degrees)}')\n",
    "print(f'Nodes with 0 out-links: {sum(1 for d in degrees if d == 0)}')\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 4))\n",
    "axes[0].hist(degrees, bins=50, log=True)\n",
    "axes[0].set_title('Out-degree distribution (log)')\n",
    "axes[0].set_xlabel('Degree')\n",
    "axes[0].set_ylabel('Count')\n",
    "axes[1].hist(degrees, bins=50, cumulative=True, density=True, histtype='step')\n",
    "axes[1].set_title('Cumulative out-degree distribution')\n",
    "axes[1].set_xlabel('Degree')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Validate: Is the next_article always a link on the current page?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def is_valid_link(curr, nxt):\n",
    "    return nxt in adj.get(curr, [])\n",
    "\n",
    "valid_mask = train.apply(lambda r: is_valid_link(r['current_article_id'], r['next_article_id']), axis=1)\n",
    "print(f'next_article is a link on current page: {valid_mask.mean()*100:.2f}% ({valid_mask.sum()}/{len(train)})')\n",
    "\n",
    "invalid = train[~valid_mask]\n",
    "if len(invalid) > 0:\n",
    "    print(f'\\n{len(invalid)} invalid examples:')\n",
    "    display(invalid.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Shortest paths between current and target in training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def bfs_dist(adj, start, target, max_dist=10):\n",
    "    if start == target:\n",
    "        return 0\n",
    "    visited = {start}\n",
    "    queue = [(start, 0)]\n",
    "    while queue:\n",
    "        node, d = queue.pop(0)\n",
    "        if node == target:\n",
    "            return d\n",
    "        if d >= max_dist:\n",
    "            continue\n",
    "        for nb in adj.get(node, []):\n",
    "            if nb not in visited:\n",
    "                visited.add(nb)\n",
    "                queue.append((nb, d + 1))\n",
    "    return max_dist\n",
    "\n",
    "# Sample 1000 for speed\n",
    "sample_train = train.sample(min(1000, len(train)), random_state=42)\n",
    "dists = [bfs_dist(adj, r['current_article_id'], r['target_article_id'], 10) \n",
    "         for _, r in sample_train.iterrows()]\n",
    "\n",
    "plt.figure(figsize=(8, 4))\n",
    "plt.hist(dists, bins=range(0, 12), align='left', rwidth=0.8)\n",
    "plt.title('BFS distance from current to target (sampled 1000)')\n",
    "plt.xlabel('Distance (capped at 10)')\n",
    "plt.ylabel('Count')\n",
    "plt.xticks(range(0, 11))\n",
    "plt.show()\n",
    "print(f'Same article (dist=0): {sum(1 for d in dists if d==0)}')\n",
    "print(f'Direct link (dist=1): {sum(1 for d in dists if d==1)}')\n",
    "print(f'2-3 hops: {sum(1 for d in dists if 2<=d<=3)}')\n",
    "print(f'4-10 hops: {sum(1 for d in dists if 4<=d<=10)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Article Embeddings\n",
    "\n",
    "Generate text embeddings from article titles using sentence-transformers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "embed_cache = CACHE / 'article_embeddings.npy'\n",
    "if embed_cache.exists():\n",
    "    article_embeddings = np.load(embed_cache)\n",
    "    print(f'Loaded cached embeddings: {article_embeddings.shape}')\n",
    "else:\n",
    "    model = SentenceTransformer('all-MiniLM-L6-v2')\n",
    "    titles = articles['title'].tolist()\n",
    "    article_embeddings = model.encode(titles, show_progress_bar=True, batch_size=64)\n",
    "    np.save(embed_cache, article_embeddings)\n",
    "    print(f'Generated embeddings: {article_embeddings.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Embedding similarity baseline sanity check\n",
    "For each training sample, compute cosine similarity between target_article embedding and every link on the current page. Is the correct next_article the most similar?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_link_similarity_scores(current_id, target_id, adj, embeddings):\n",
    "    links = adj.get(current_id, [])\n",
    "    if not links:\n",
    "        return None, None\n",
    "    target_emb = embeddings[target_id]\n",
    "    link_embs = embeddings[links]\n",
    "    scores = link_embs @ target_emb\n",
    "    return links, scores\n",
    "\n",
    "def link_similarity_accuracy(adj, embeddings, train_df, n_samples=2000):\n",
    "    correct = 0\n",
    "    total = 0\n",
    "    df = train_df.sample(min(n_samples, len(train_df)), random_state=42)\n",
    "    for _, row in df.iterrows():\n",
    "        links, scores = compute_link_similarity_scores(\n",
    "            row['current_article_id'], row['target_article_id'], adj, embeddings)\n",
    "        if links is None:\n",
    "            continue\n",
    "        pred = links[scores.argmax()]\n",
    "        if pred == row['next_article_id']:\n",
    "            correct += 1\n",
    "        total += 1\n",
    "    return correct / total if total > 0 else 0.0\n",
    "\n",
    "acc = link_similarity_accuracy(adj, article_embeddings, train)\n",
    "print(f'Title-embedding similarity baseline accuracy: {acc*100:.2f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Category Features\n",
    "\n",
    "Encode categories as multi-hot vectors."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "all_categories = sorted(categories['category'].unique())\n",
    "cat_to_idx = {c: i for i, c in enumerate(all_categories)}\n",
    "n_cats = len(all_categories)\n",
    "print(f'Unique categories: {n_cats}')\n",
    "\n",
    "# Multi-hot encoding\n",
    "cat_encoding = np.zeros((len(articles), n_cats), dtype=np.float32)\n",
    "for _, row in categories.iterrows():\n",
    "    cat_encoding[row['article_id'], cat_to_idx[row['category']]] = 1.0\n",
    "\n",
    "# Top categories\n",
    "top_cats = categories['category'].value_counts().head(15)\n",
    "plt.figure(figsize=(10, 4))\n",
    "top_cats.plot(kind='bar')\n",
    "plt.title('Top 15 categories')\n",
    "plt.ylabel('Count')\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Category overlap heuristic\n",
    "Pick the link from current page that shares the most categories with the target."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def category_overlap_accuracy(adj, cat_enc, train_df, n_samples=2000):\n",
    "    correct = 0\n",
    "    total = 0\n",
    "    df = train_df.sample(min(n_samples, len(train_df)), random_state=42)\n",
    "    for _, row in df.iterrows():\n",
    "        links = adj.get(row['current_article_id'], [])\n",
    "        if not links:\n",
    "            continue\n",
    "        target_cats = cat_enc[row['target_article_id']][None, :]\n",
    "        link_cats = cat_enc[links]\n",
    "        overlap = (link_cats * target_cats).sum(axis=1)\n",
    "        pred = links[overlap.argmax()]\n",
    "        if pred == row['next_article_id']:\n",
    "            correct += 1\n",
    "        total += 1\n",
    "    return correct / total if total > 0 else 0.0\n",
    "\n",
    "cat_acc = category_overlap_accuracy(adj, cat_encoding, train)\n",
    "print(f'Category overlap baseline accuracy: {cat_acc*100:.2f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. CLIP Visual Embeddings from Screenshots\n",
    "\n",
    "Extract visual features from article screenshots using a pre-trained vision model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "clip_cache = CACHE / 'clip_embeddings.npy'\n",
    "\n",
    "if clip_cache.exists():\n",
    "    clip_embeddings = np.load(clip_cache)\n",
    "    print(f'Loaded cached CLIP embeddings: {clip_embeddings.shape}')\n",
    "else:\n",
    "    from transformers import CLIPProcessor, CLIPModel\n",
    "    clip_model = CLIPModel.from_pretrained('openai/clip-vit-base-patch32')\n",
    "    clip_processor = CLIPProcessor.from_pretrained('openai/clip-vit-base-patch32')\n",
    "    clip_model.eval()\n",
    "    \n",
    "    all_embs = []\n",
    "    screenshot_dir = DATA / 'screenshots'\n",
    "    for aid in tqdm(range(len(articles)), desc='CLIP embeddings'):\n",
    "        fname = screenshot_dir / f'{aid}.png'\n",
    "        if not fname.exists():\n",
    "            all_embs.append(np.zeros(512, dtype=np.float32))\n",
    "            continue\n",
    "        image = Image.open(fname).convert('RGB')\n",
    "        inputs = clip_processor(images=image, return_tensors='pt')\n",
    "        with torch.no_grad():\n",
    "            emb = clip_model.get_image_features(**inputs).numpy().flatten()\n",
    "        all_embs.append(emb)\n",
    "    clip_embeddings = np.array(all_embs, dtype=np.float32)\n",
    "    np.save(clip_cache, clip_embeddings)\n",
    "    print(f'Generated CLIP embeddings: {clip_embeddings.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Build Feature Matrices & Save\n",
    "\n",
    "Save all preprocessed features for downstream models."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Combined features (text + visual, can be used by XGBoost / GNN)\n",
    "combined = np.concatenate([article_embeddings, clip_embeddings, cat_encoding], axis=1)\n",
    "print(f'Combined feature shape: {combined.shape}')\n",
    "\n",
    "np.save(CACHE / 'combined_features.npy', combined)\n",
    "np.save(CACHE / 'article_embeddings.npy', article_embeddings)\n",
    "np.save(CACHE / 'clip_embeddings.npy', clip_embeddings)\n",
    "np.save(CACHE / 'cat_encoding.npy', cat_encoding)\n",
    "\n",
    "with open(CACHE / 'adj.pkl', 'wb') as f:\n",
    "    pickle.dump(adj, f)\n",
    "\n",
    "print('All features saved.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Test Data Preparation\n",
    "\n",
    "For each test state, find candidate links (articles linked from current page)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def prepare_state_features(states_df, adj, embeddings):\n",
    "    rows = []\n",
    "    for _, row in states_df.iterrows():\n",
    "        curr = row['current_article_id']\n",
    "        tgt = row['target_article_id']\n",
    "        links = adj.get(curr, [])\n",
    "        if not links:\n",
    "            # Fallback: predict the target itself if no links\n",
    "            links = [tgt]\n",
    "        curr_emb = embeddings[curr]\n",
    "        tgt_emb = embeddings[tgt]\n",
    "        for link in links:\n",
    "            link_emb = embeddings[link]\n",
    "            sim = float(link_emb @ tgt_emb)\n",
    "            rows.append({\n",
    "                'state_id': row['state_id'],\n",
    "                'current_id': curr,\n",
    "                'target_id': tgt,\n",
    "                'candidate_id': link,\n",
    "                'cosine_sim': sim,\n",
    "            })\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "test_features = prepare_state_features(test, adj, article_embeddings)\n",
    "print(f'Test features: {test_features.shape}')\n",
    "test_features.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Submission Helper\n",
    "\n",
    "Format and save predictions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_submission(state_ids, predictions, tag='baseline'):\n",
    "    from datetime import datetime\n",
    "    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n",
    "    sub_dir = ROOT / 'submissions' / f'{timestamp}_{tag}'\n",
    "    sub_dir.mkdir(parents=True, exist_ok=True)\n",
    "    \n",
    "    sub_path = sub_dir / 'submission.csv'\n",
     "    _make_sub(state_ids, predictions, sub_path)\n",
    "    print(f'Saved: {sub_path}')\n",
    "    return sub_dir"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('EDA complete.')\n",
    "print(f'Summary:')\n",
    "print(f'  - {len(articles)} articles')\n",
    "print(f'  - {sum(len(v) for v in adj.values())} directed links')\n",
    "print(f'  - {len(train)} train states, {len(test)} test states')\n",
    "print(f'  - Text embedding dim: {article_embeddings.shape[1]}')\n",
    "print(f'  - CLIP embedding dim: {clip_embeddings.shape[1]}')\n",
    "print(f'  - Category encoding dim: {cat_encoding.shape[1]}')"
   ]
  }
